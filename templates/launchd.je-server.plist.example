<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.unmc.java-server-stack.je</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/screen</string>
    <string>-DmS</string>
    <string>unmc-je</string>
    <string>__REPO_PATH__/scripts/start-je.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_PATH__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__REPO_PATH__/logs/launchd-je.out.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO_PATH__/logs/launchd-je.err.log</string>
</dict>
</plist>
