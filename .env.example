# Copy this file to .env and edit it before running the stack.

# Local Minecraft server
MC_PORT=25565
MC_LOCAL_HOST=127.0.0.1
MC_MIN_RAM=1G
MC_MAX_RAM=3G
SERVER_JAR_PATTERN=*.jar

# Public entry probes shown in the panel.
# First host = primary relay, second/extra hosts = optional regional relays.
MC_ENTRY_HOSTS=play.example.com,la.play.example.com

# SSH reverse tunnel from the Mac mini to the primary relay server.
REMOTE_HOST=relay.example.com
REMOTE_USER=minecraft_tunnel
REMOTE_SSH_PORT=22
REMOTE_BIND=0.0.0.0
REMOTE_FORWARD_PORT=25565
LOCAL_HOST=127.0.0.1
LOCAL_PORT=25565
SSH_KEY_PATH=${HOME}/.ssh/unmc_tunnel_ed25519
SSH_KNOWN_HOSTS_FILE=${HOME}/.ssh/known_hosts

# Local web panel. Keep this on localhost unless you add authentication.
PANEL_HOST=127.0.0.1
PANEL_PORT=8765
PANEL_URL=http://127.0.0.1:8765

# Screen session names.
SCREEN_PREFIX=unmc
SERVER_SCREEN_NAME=unmc-je
TUNNEL_SCREEN_NAME=unmc-tunnel
PANEL_SCREEN_NAME=unmc-panel
